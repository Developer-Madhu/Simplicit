{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "@next/next/no-html-link-for-pages": "off",
    "import/no-restricted-paths": [
      "error",
      {
        "zones": [
          {
            "target": "./src/features",
            "from": "./src/app"
          },
          {
            "target": [
              "./src/components",
              "./src/hooks",
              "./src/lib",
              "./src/types",
              "./src/utils"
            ],
            "from": ["./src/features", "./src/app"]
          }
        ]
      }
    ]
  }
}

